{
  "name": "asn-pos-desktop",
  "version": "1.0.0",
  "description": "ASN POS Desktop Application - Offline-first POS system",
  "main": "electron/main.js",
  "author": "ASN Technology",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "build:next": "cd .. && npm run build",
    "build:copy": "node build-desktop.js",
    "build:win": "electron-builder --win --config electron-builder.yml",
    "build:asn": "electron-builder --win --config electron-builder.yml",
    "build:atyab": "electron-builder --win --config electron-builder-atyab.yml",
    "build": "npm run build:next && npm run build:copy && npm run build:win",
    "build:all": "npm run build:next && npm run build:copy && npm run build:asn && npm run build:atyab",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "dotenv": "^17.3.1",
    "electron-store": "^10.0.1",
    "electron-updater": "^6.3.9",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^26.8.1"
  }
}
